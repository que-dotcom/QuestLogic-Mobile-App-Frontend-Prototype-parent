# API設定
# バックエンドのオリジン（末尾スラッシュなし・/api は含めない）
# apiFetch('/api/quests') のようにパス側に /api を含める
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# APIタイムアウト（ミリ秒）
EXPO_PUBLIC_API_TIMEOUT=10000

# Google OAuth設定
# Google Cloud Console > 認証情報 > OAuthクライアントID（ウェブアプリケーション）で発行
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=

# 開発用テストAPIのBasic認証情報（本番ビルドでは不要）
EXPO_PUBLIC_TEST_USER=admin
EXPO_PUBLIC_TEST_PASS=Quest2404
