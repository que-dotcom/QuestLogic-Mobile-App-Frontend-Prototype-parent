{
  "expo": {
    "name": "親用アプリ",
    "slug": "parent-app",
    "scheme": "com.raitsumugu.parent-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.raitsumugu.parent-app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FDFDFD"
      },
      "package": "com.raitsumugu.parentapp",
      "scheme": "com.raitsumugu.parentapp"
    },
    "web": {},
    "plugins": [
      "expo-web-browser",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "0081d568-4c69-400a-adcf-4cba70a37ef1"
      }
    },
    "owner": "raitsumugu"
  }
}
